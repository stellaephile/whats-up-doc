# Delhi Health-Hacker Environment Configuration

# Data.gov.in API Configuration
DATA_GOV_IN_API_KEY=your_data_gov_in_api_key_here

# Server Configuration
PORT=3000
NODE_ENV=development

# Database Configuration (if needed later)
# DATABASE_URL=postgresql://username:password@localhost:5432/delhi_health_hacker

# Redis Configuration (for caching)
# REDIS_URL=redis://localhost:6379

# Maps API (if using Google Maps or other mapping service)
# GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here
# MAPBOX_ACCESS_TOKEN=your_mapbox_token_here

# Security Configuration
# JWT_SECRET=your_jwt_secret_for_sessions
# CORS_ORIGIN=http://localhost:3000

# Logging Configuration
LOG_LEVEL=info

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Cache Configuration
CACHE_EXPIRY_MINUTES=30
HOSPITAL_DATA_REFRESH_HOURS=24